model patch {
  id                   Int      @id @default(autoincrement())
  name_en_us           String   @db.VarChar(1007) @default("")
  name_zh_cn           String   @db.VarChar(1007) @default("")
  name_ja_jp           String   @db.VarChar(1007) @default("")
  vndb_id              String?  @unique @db.VarChar(107)
  // Bangumi Subject ID
  bid                  Int?     @unique
  banner               String   @default("") @db.VarChar(1007)

  introduction_zh_cn   String   @default("") @db.VarChar(100007)
  introduction_ja_jp   String   @default("") @db.VarChar(100007)
  introduction_en_us   String   @default("") @db.VarChar(100007)
  released             String   @default("unknown") @db.VarChar(107)
  content_limit        String   @default("sfw") @db.VarChar(107)
  status               Int      @default(0)
  download             Int      @default(0)
  view                 Int      @default(0)
  resource_update_time DateTime @default(now())
  type                 Json     @default("[]") @db.JsonB
  language             Json     @default("[]") @db.JsonB
  engine               Json     @default("[]") @db.JsonB
  platform             Json     @default("[]") @db.JsonB

  // Denormalized counts for GORM compatibility (avoid _count subqueries)
  favorite_count   Int @default(0)
  contribute_count Int @default(0)
  comment_count    Int @default(0)
  resource_count   Int @default(0)

  // NOTE: 以下元数据关系按 D8/D11（2026-04-21）废弃，统一走 Galgame Wiki Service：
  //   cover / screenshot / char_rel / person_rel / release（D8）
  //   tag / company（D11）
  // 本地只保留对外站链接和补丁自身数据。

  link        patch_link[]

  user_id Int
  user    user @relation("user_patch", fields: [user_id], references: [id])

  alias         patch_alias[]
  favorite_by   user_patch_favorite_relation[]
  contribute_by user_patch_contribute_relation[]

  resource patch_resource[]     @relation("patch_resource")
  comment  patch_comment[]      @relation("patch_comment")

  created DateTime @default(now())
  updated DateTime @updatedAt
}
